<style>
  :root{
    --cream:#FFF8F0;
    --pink:#FFB6C1;
    --pink-deep:#F49AAB;
    --gold:#FFE4A0;
    --ink:#4A3B3B;
    --ink-light:#8A7A78;
    --white:#FFFFFF;

    --kim:#C9962E;     --kim-tint:#F4E9CC;
    --moc:#5E8A52;     --moc-tint:#E1ECDA;
    --thuy:#3F6B9E;    --thuy-tint:#DCE6F2;
    --hoa:#D1572D;     --hoa-tint:#F8DDD0;
    --tho:#B3905E;     --tho-tint:#F0E5D0;

    --radius-lg:28px;
    --radius-md:18px;
    --shadow-soft:0 14px 34px -16px rgba(74,59,59,0.28);
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Be Vietnam Pro', sans-serif;
    color:var(--ink);
    background:var(--cream);
    line-height:1.6;
    overflow-x:hidden;
  }
  img,svg{display:block; max-width:100%;}
  a{text-decoration:none; color:inherit;}
  ul{list-style:none;}
  .container{max-width:1140px; margin:0 auto; padding:0 24px;}
  .eyebrow{
    font-family:'Quicksand', sans-serif;
    font-weight:700;
    letter-spacing:.14em;
    text-transform:uppercase;
    font-size:.78rem;
    color:var(--pink-deep);
  }
  h1,h2,h3{font-family:'Be Vietnam Pro', sans-serif; font-weight:800; line-height:1.2;}
  .section-pad{padding:88px 0;}
  .section-head{max-width:620px; margin:0 auto 48px; text-align:center;}
  .section-head h2{font-size:clamp(1.7rem,3vw,2.3rem); margin-top:10px;}
  .section-head p{color:var(--ink-light); margin-top:12px; font-size:1.02rem;}

  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    font-family:'Quicksand', sans-serif; font-weight:700; font-size:.98rem;
    padding:14px 28px; border-radius:999px; border:2px solid transparent;
    cursor:pointer; transition:transform .18s ease, box-shadow .18s ease, background .18s ease;
    white-space:nowrap;
  }
  .btn:hover{transform:translateY(-2px);}
  .btn:focus-visible{outline:3px solid var(--pink-deep); outline-offset:3px;}
  .btn-primary{background:var(--pink); color:#5A2B36; box-shadow:var(--shadow-soft);}
  .btn-primary:hover{background:var(--pink-deep); color:#fff;}
  .btn-outline{background:transparent; border-color:var(--ink); color:var(--ink);}
  .btn-outline:hover{background:var(--ink); color:var(--cream);}
  .btn-small{padding:10px 20px; font-size:.88rem;}

  /* ===== HEADER ===== */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(255,248,240,0.86);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(74,59,59,0.08);
  }
  .nav-wrap{display:flex; align-items:center; justify-content:space-between; padding:16px 24px;}
  .logo{display:flex; align-items:center; gap:10px; font-family:'Quicksand',sans-serif; font-weight:700; font-size:1.18rem; letter-spacing:.02em;}
  .logo small{display:block; font-family:'Be Vietnam Pro'; font-weight:400; font-size:.62rem; color:var(--ink-light); letter-spacing:.08em;}
  .nav-links{display:flex; gap:30px; align-items:center; font-family:'Quicksand',sans-serif; font-weight:600; font-size:.95rem;}
  .nav-links a{padding:6px 2px; border-bottom:2px solid transparent; transition:border-color .2s;}
  .nav-links a:hover{border-color:var(--pink-deep);}
  .nav-toggle{display:none; background:none; border:none; font-size:1.4rem; cursor:pointer; color:var(--ink);}

  @media (max-width:860px){
    .nav-links{
      position:absolute; top:100%; left:0; right:0;
      flex-direction:column; align-items:flex-start; gap:0;
      background:var(--cream); padding:0 24px;
      max-height:0; overflow:hidden; transition:max-height .3s ease;
      border-bottom:1px solid rgba(74,59,59,0.08);
    }
    .nav-links.open{max-height:320px; padding:14px 24px 22px;}
    .nav-links a{width:100%; padding:10px 0;}
    .nav-toggle{display:block;}
  }

  /* ===== HERO ===== */
  .hero{position:relative; overflow:hidden; padding:64px 0 90px;}
  .hero::before{
    content:""; position:absolute; inset:-20% -10% auto -10%; height:480px;
    background:radial-gradient(circle at 30% 30%, rgba(255,182,193,0.45), transparent 60%),
               radial-gradient(circle at 80% 10%, rgba(255,228,160,0.55), transparent 55%);
    z-index:0;
  }
  .hero-grid{position:relative; z-index:1; display:grid; grid-template-columns:1.05fr .95fr; gap:56px; align-items:center;}
  .hero h1{font-size:clamp(2rem,4vw,3.1rem); margin-top:14px;}
  .hero h1 .accent{color:var(--pink-deep);}
  .hero p.lead{margin-top:18px; font-size:1.08rem; color:var(--ink-light); max-width:480px;}
  .hero-ctas{margin-top:30px; display:flex; gap:14px; flex-wrap:wrap;}

  /* signature wheel */
  .wheel-frame{display:flex; justify-content:center;}
  .wheel{position:relative; width:320px; height:320px; --r:125px;}
  .wheel-ring{
    position:absolute; inset:0; border-radius:50%;
    background:conic-gradient(
      var(--moc) 0deg 72deg,
      var(--hoa) 72deg 144deg,
      var(--tho) 144deg 216deg,
      var(--kim) 216deg 288deg,
      var(--thuy) 288deg 360deg
    );
    box-shadow:var(--shadow-soft);
    animation:spin 70s linear infinite;
  }
  @keyframes spin{ to{ transform:rotate(360deg); } }
  @media (prefers-reduced-motion:reduce){ .wheel-ring{animation:none;} }
  .wheel-center{
    position:absolute; inset:70px; border-radius:50%;
    background:var(--white); display:flex; flex-direction:column; align-items:center; justify-content:center;
    box-shadow:inset 0 0 0 1px rgba(74,59,59,0.06);
    text-align:center; padding:8px;
  }
  .wheel-center span{font-family:'Quicksand',sans-serif; font-weight:700; font-size:.74rem; color:var(--ink-light); margin-top:6px; letter-spacing:.06em;}
  .wheel-label{
    position:absolute; top:50%; left:50%;
    font-family:'Quicksand',sans-serif; font-weight:700; font-size:.86rem; color:#fff;
    text-shadow:0 1px 3px rgba(0,0,0,0.25);
  }
  .wl-moc{transform:translate(-50%,-50%) rotate(36deg) translateY(calc(var(--r) * -1)) rotate(-36deg);}
  .wl-hoa{transform:translate(-50%,-50%) rotate(108deg) translateY(calc(var(--r) * -1)) rotate(-108deg);}
  .wl-tho{transform:translate(-50%,-50%) rotate(180deg) translateY(calc(var(--r) * -1)) rotate(-180deg);}
  .wl-kim{transform:translate(-50%,-50%) rotate(252deg) translateY(calc(var(--r) * -1)) rotate(-252deg);}
  .wl-thuy{transform:translate(-50%,-50%) rotate(324deg) translateY(calc(var(--r) * -1)) rotate(-324deg);}

  @media (max-width:980px){
    .hero-grid{grid-template-columns:1fr; text-align:center;}
    .hero p.lead{margin-left:auto; margin-right:auto;}
    .hero-ctas{justify-content:center;}
  }
  @media (max-width:480px){
    .wheel{width:230px; height:230px; --r:90px;}
    .wheel-center{inset:50px;}
  }

  /* ===== WHY ===== */
  .why-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:26px;}
  .why-card{
    background:var(--white); border-radius:var(--radius-md); padding:32px 26px;
    box-shadow:var(--shadow-soft); text-align:left;
  }
  .why-icon{width:46px; height:46px; border-radius:50%; background:var(--gold); display:flex; align-items:center; justify-content:center; margin-bottom:18px;}
  .why-card h3{font-size:1.12rem; margin-bottom:8px;}
  .why-card p{color:var(--ink-light); font-size:.96rem;}
  @media (max-width:860px){ .why-grid{grid-template-columns:1fr;} }

  /* ===== PRODUCTS ===== */
  .products-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px;}
  .product-card{
    background:var(--white); border-radius:var(--radius-md); overflow:hidden;
    box-shadow:var(--shadow-soft); display:flex; flex-direction:column;
    border-top:6px solid var(--accent);
  }
  .product-thumb{
    height:140px; background:linear-gradient(135deg, var(--tint), var(--cream));
    display:flex; align-items:center; justify-content:center;
  }
  .product-body{padding:22px; display:flex; flex-direction:column; gap:10px; flex:1;}
  .badge{
    align-self:flex-start; font-family:'Quicksand',sans-serif; font-weight:700; font-size:.74rem;
    padding:5px 12px; border-radius:999px; background:var(--tint); color:var(--accent); letter-spacing:.03em;
  }
  .product-card h3{font-size:1.08rem;}
  .product-card .price{font-family:'Quicksand',sans-serif; font-weight:700; color:var(--ink); font-size:1.02rem; margin-top:auto;}
  .product-card .btn{margin-top:6px; align-self:flex-start;}
  @media (max-width:980px){ .products-grid{grid-template-columns:repeat(2,1fr);} }
  @media (max-width:620px){ .products-grid{grid-template-columns:1fr;} }

  /* ===== QUIZ ===== */
  .quiz{background:linear-gradient(135deg, var(--gold) 0%, var(--pink) 100%);}
  .quiz-card{
    max-width:560px; margin:0 auto; background:var(--white); border-radius:var(--radius-lg);
    padding:40px; box-shadow:var(--shadow-soft); text-align:center;
  }
  .quiz-card p{color:var(--ink-light); margin-top:10px;}
  .quiz-form{display:flex; gap:10px; margin-top:26px; flex-wrap:wrap; justify-content:center;}
  .quiz-form input{
    flex:1; min-width:180px; padding:14px 18px; border-radius:999px;
    border:2px solid rgba(74,59,59,0.15); font-family:'Be Vietnam Pro'; font-size:1rem;
  }
  .quiz-form input:focus-visible{outline:3px solid var(--pink-deep); border-color:var(--pink-deep);}
  .quiz-result{
    margin-top:26px; border-radius:var(--radius-md); padding:0; max-height:0; overflow:hidden;
    transition:max-height .35s ease, padding .35s ease;
    background:var(--cream); --accent:#D1572D;
  }
  .quiz-result.show{max-height:320px; padding:24px;}
  .quiz-result-label{font-family:'Quicksand',sans-serif; font-weight:600; color:var(--ink-light); font-size:.92rem;}
  .quiz-result-menh{font-size:1.8rem; font-weight:800; color:var(--accent); margin:6px 0;}
  .quiz-result-desc{color:var(--ink-light); font-size:.95rem; margin-bottom:16px;}
  .quiz-error{color:#B23A3A; font-weight:600;}

  /* ===== TESTIMONIALS ===== */
  .test-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px;}
  .test-card{background:var(--white); border-radius:var(--radius-md); padding:28px; box-shadow:var(--shadow-soft);}
  .stars{color:var(--pink-deep); letter-spacing:2px; font-size:1rem;}
  .test-card p.quote{margin-top:14px; color:var(--ink); font-size:.97rem;}
  .test-card .who{margin-top:16px; font-family:'Quicksand',sans-serif; font-weight:700; font-size:.92rem;}
  .test-card .where{color:var(--ink-light); font-size:.84rem; font-weight:500;}
  @media (max-width:860px){ .test-grid{grid-template-columns:1fr;} }

  /* ===== ORDER / TALLY EMBED ===== */
  .order{background:var(--white);}
  .order-card{
    max-width:720px; margin:0 auto; border-radius:var(--radius-lg);
    padding:30px; background:var(--cream); box-shadow:var(--shadow-soft);
  }
  .tally-embed-wrapper{border-radius:var(--radius-md); overflow:hidden; background:var(--white);}
  .tally-embed-wrapper iframe{width:100%; border:none; display:block;}
  .order-note{font-size:.86rem; color:var(--ink-light); margin-top:14px; text-align:center;}

  /* ===== FOOTER ===== */
  footer{background:#3F3134; color:#F4E9E6; padding:56px 0 26px;}
  .footer-grid{display:flex; justify-content:space-between; gap:30px; flex-wrap:wrap;}
  .footer-brand{font-family:'Quicksand',sans-serif; font-weight:700; font-size:1.2rem;}
  .footer-brand p{color:#C9B8B6; font-size:.9rem; margin-top:10px; max-width:280px;}
  .footer-col h4{font-family:'Quicksand',sans-serif; font-size:.9rem; letter-spacing:.06em; text-transform:uppercase; color:#E8A8B6; margin-bottom:14px;}
  .footer-col a, .footer-col p{display:block; color:#D9CAC8; font-size:.92rem; margin-bottom:8px;}
  .footer-col a:hover{color:#fff;}
  .footer-bottom{margin-top:40px; padding-top:20px; border-top:1px solid rgba(255,255,255,0.1); font-size:.82rem; color:#A8989A; text-align:center;}
</style>
</head>
