<script>
  // Toggle menu mobile
  document.getElementById('navToggle').addEventListener('click', function(){
    document.getElementById('navLinks').classList.toggle('open');
  });

  // Quiz tra mệnh theo năm sinh (dựa theo Thiên Can - cách tính phổ biến)
  function tinhMenh(year){
    var mapping = {0:'kim',1:'kim',2:'thuy',3:'thuy',4:'moc',5:'moc',6:'hoa',7:'hoa',8:'tho',9:'tho'};
    var d = ((year % 10) + 10) % 10;
    return mapping[d];
  }
  var menhInfo = {
    kim:  {ten:'Kim',  mota:'Bạn hợp các tông trắng bạc, ánh kim — sang trọng và sắc sảo.'},
    moc:  {ten:'Mộc',  mota:'Bạn hợp các tông xanh lá, nâu gỗ — tươi mới và tràn sức sống.'},
    thuy: {ten:'Thủy', mota:'Bạn hợp các tông xanh dương, đen — sâu sắc và linh hoạt.'},
    hoa:  {ten:'Hỏa',  mota:'Bạn hợp các tông đỏ, cam — năng động và nổi bật.'},
    tho:  {ten:'Thổ',  mota:'Bạn hợp các tông vàng đất, be — ấm áp và vững chãi.'}
  };
  var accentVar = {kim:'var(--kim)', moc:'var(--moc)', thuy:'var(--thuy)', hoa:'var(--hoa)', tho:'var(--tho)'};

  document.getElementById('quiz-form').addEventListener('submit', function(e){
    e.preventDefault();
    var year = parseInt(document.getElementById('quiz-year').value, 10);
    var resultBox = document.getElementById('quiz-result');
    if(!year || year < 1900 || year > 2026){
      resultBox.innerHTML = '<p class="quiz-error">Vui lòng nhập năm sinh hợp lệ (1900–2026).</p>';
      resultBox.classList.add('show');
      return;
    }
    var menh = tinhMenh(year);
    var info = menhInfo[menh];
    resultBox.style.setProperty('--accent', accentVar[menh]);
    resultBox.innerHTML =
      '<p class="quiz-result-label">Năm ' + year + ' — bạn thuộc mệnh</p>' +
      '<p class="quiz-result-menh">' + info.ten + '</p>' +
      '<p class="quiz-result-desc">' + info.mota + '</p>' +
      '<a class="btn btn-primary btn-small" href="#san-pham-' + menh + '">Xem kẹp tóc hợp mệnh ' + info.ten + '</a>';
    resultBox.classList.add('show');
  });
</script>

